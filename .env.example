# Database
# ---------
# PostgreSQL (Neon — ganti dengan credentials kamu sendiri):
# DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"
#
# ⚠️ Jangan tambahkan `channel_binding=require` — bisa menyebabkan P1002 timeout
#    di environment serverless seperti Vercel.
#
# Local dev (SQLite — ubah provider di prisma/schema.prisma ke "sqlite"):
# DATABASE_URL="file:./dev.db"

# Admin Auth
# -----------
# Single admin credential (no user management / registration)
ADMIN_EMAIL=admin@example.com
#
# Generate hash with:
#   node -e "const {scryptSync,randomBytes}=require('crypto'); const s=randomBytes(16).toString('base64'); const k=scryptSync('your-password',s,64).toString('base64'); console.log(s+':'+k)"
ADMIN_PASSWORD_HASH=generate-with-script-above
#
# Generate session secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-with-script-above

# Email (Resend — untuk kirim OTP 2FA)
# --------------------------------------
# Dapatkan API key dari https://resend.com/api-keys
# Format: re_xxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxx

# Vercel Deployment
# ------------------
# Set these environment variables in Vercel Project Settings → Environment Variables:
# 1. DATABASE_URL — connection string PostgreSQL kamu
# 2. ADMIN_EMAIL — email admin login
# 3. ADMIN_PASSWORD_HASH — hasil generate hash
# 4. SESSION_SECRET — hasil generate session secret
