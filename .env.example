# Database
# ---------
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
#
# Production (Postgres/Neon — uncomment and set your connection string):
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/shopby?sslmode=require"

# Admin Auth
# -----------
# Single admin credential (no user management / registration)
ADMIN_EMAIL=admin@shopby.com
#
# Generate hash with:
#   node -e "const {scryptSync,randomBytes}=require('crypto'); const s=randomBytes(16).toString('base64'); const k=scryptSync('your-password',s,64).toString('base64'); console.log(s+':'+k)"
ADMIN_PASSWORD_HASH=ROutpODD0n4AzloJtFWQKA==:KrZlEnmnKSwZeY6A6v36HWsrp4FbmX3QQjJXiY9l6xlalQx5ipVvzsiK2oYL9Vvq2GT7oiaIgSatj/Tzmp/pNg==
#
# Generate session secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-random-string-at-least-32-chars-long

# Vercel Deployment
# ------------------
# Set these environment variables in Vercel Project Settings → Environment Variables:
# 1. DATABASE_URL — your Postgres connection string
# 2. ADMIN_EMAIL — your admin email
# 3. ADMIN_PASSWORD_HASH — generate with the command above
# 4. SESSION_SECRET — generate with the command above
# 5. NODE_VERSION — "20.x" (set if needed)
